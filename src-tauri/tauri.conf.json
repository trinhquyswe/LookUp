{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LookUp",
  "version": "0.1.0",
  "identifier": "com.usopp.lookup",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LookUp",
        "url": "index.html",
        "width": 800,
        "height": 600,
        "visible": false,
        "skipTaskbar": false
      },
      {
        "label": "popup",
        "title": "LookUp",
        "url": "popup.html",
        "width": 320,
        "height": 160,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "tooltip": "LookUp — Ctrl+Shift+Space to detect word"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "models/text-detection.rten",
      "models/text-recognition.rten"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
